{
  "enabled": true,
  "name": "Auto Run Benchmark Tests",
  "description": "Setelah file Go benchmark test diedit, otomatis jalankan benchmark dan simpan hasil ke reports/backend/.",
  "version": "1",
  "when": {
    "type": "fileEdited",
    "patterns": [
      "**/*_test.go"
    ]
  },
  "then": {
    "type": "runCommand",
    "command": "mkdir -p reports/backend && cd backend && go test ./... -bench=. -benchmem -count=3 -run=^$ > ../reports/backend/benchmark-results.txt 2>&1; echo '--- Benchmark Done ---'; tail -20 ../reports/backend/benchmark-results.txt",
    "timeout": 180
  }
}
