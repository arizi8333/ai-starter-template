{
  "enabled": true,
  "name": "Auto Run Benchmark Tests",
  "description": "Run Go benchmarks on demand for updated benchmark files with structured output and minimal overhead.",
  "version": "2",
  "when": {
    "type": "fileSaved",
    "patterns": ["**/*_test.go"],
    "condition": "file.contains('Benchmark') == true"
  },
  "then": {
    "type": "runCommand",
    "command": "mkdir -p reports/backend && cd backend && go test ./... -bench=. -benchmem -run=^$ -count=2 -benchtime=100ms -json > ../reports/backend/benchmark-results.json 2>&1; echo '--- Benchmark Done ---'; tail -20 ../reports/backend/benchmark-results.json",
    "timeout": 120
  }
}