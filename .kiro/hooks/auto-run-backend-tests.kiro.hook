{
  "enabled": true,
  "name": "Auto Run Backend Tests",
  "description": "Run Go tests with coverage for updated test files with fast feedback and structured output.",
  "version": "2",
  "when": {
    "type": "fileSaved",
    "patterns": ["**/*_test.go"],
    "condition": "file.size < 2000"
  },
  "then": {
    "type": "runCommand",
    "command": "mkdir -p reports/backend && cd backend && go test ./... -count=1 -coverprofile=../reports/backend/coverage.out -json > ../reports/backend/test-results.json 2>&1; go tool cover -func=../reports/backend/coverage.out > ../reports/backend/coverage-summary.txt 2>/dev/null; go tool cover -html=../reports/backend/coverage.out -o ../reports/backend/coverage.html 2>/dev/null; echo '--- Coverage Summary ---'; tail -5 ../reports/backend/coverage-summary.txt; echo '--- Done ---'",
    "timeout": 90
  }
}